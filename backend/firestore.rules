rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.role == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Function to check if user is the owner of the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow a user to create their own profile document with 'user' role on registration
      allow create: if request.auth != null && 
                    request.auth.uid == userId && 
                    request.resource.data.role == 'user';
                    
      // Allow updates and deletes only by admin accounts
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      // Orders are created securely via server-side Admin SDK, so client writes are denied
      allow write: if isAdmin();
    }

    match /user_interactions/{interactionId} {
      allow read, write: if isAdmin();
    }
  }
}
